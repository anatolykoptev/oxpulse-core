    "@oxpulse/wire-codec": "0.3.0",
    "sframe-ratchet": "0.5.0"
  },
  "peerDependencies": {
    "@capacitor/core": "^6.2.1",
    "@capacitor-community/bluetooth-le": "^6.1.0"
  },
  "peerDependenciesMeta": {
