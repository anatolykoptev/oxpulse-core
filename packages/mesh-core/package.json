{
  "name": "@oxpulse/mesh-core",
  "version": "0.1.0",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "description": "BLE / WiFi-Direct offline mesh transport for oxpulse-chat (Phase B.1+)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
