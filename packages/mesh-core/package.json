      "optional": true
    },
    "@capacitor-community/bluetooth-le": {
      "optional": true
    }
  },
  "devDependencies": {
    "@capacitor/core": "^6.2.1",
    "@capacitor-community/bluetooth-le": "^6.1.0",
    "@types/node": "^22",
    "jsdom": "^26.0.0",
    "rimraf": "^5",
    "typescript": "^6.0.3",
