{
  "name": "oxpulse-core-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "OxPulse core platform primitives — Ed25519 device identity + BLE/WiFi-Direct offline mesh transport. Shared by oxpulse-chat (messenger) and call surfaces.",
  "license": "AGPL-3.0-or-later",
  "author": "Anatoly Koptev <anatoly@koptev.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anatolykoptev/oxpulse-core.git"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "changeset": "changeset",
    "changeset:status": "changeset status --since=origin/main",
    "changeset:version": "changeset version && pnpm install --lockfile-only",
    "changeset:publish": "changeset publish"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0"
  }
}
